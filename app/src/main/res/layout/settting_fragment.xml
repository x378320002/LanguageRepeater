<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/color_background"
  android:orientation="vertical">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="wrap_content"
    android:layout_marginTop="15dp"
    android:layout_height="46dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/ib_back"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingEnd="@dimen/setting_out_margin"
      android:paddingStart="@dimen/setting_out_margin"
      android:scaleType="centerInside"
      android:src="@drawable/ic_arrow_left"
      app:tint="@color/color_selector_on_background"
      tools:ignore="ContentDescription" />

    <TextView
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toEndOf="@id/ib_back"
      app:layout_goneMarginStart="@dimen/setting_out_margin"
      android:layout_marginBottom="2dp"
      android:fontFamily="sans-serif-medium"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:text="@string/setting_title"
      android:textColor="@color/color_on_background"
      android:includeFontPadding="false"
      android:textSize="20dp"
      app:layout_constrainedWidth="true"
      tools:ignore="SpUsage"
      tools:text="Setting" />
  </androidx.constraintlayout.widget.ConstraintLayout>

  <androidx.core.widget.NestedScrollView
    android:overScrollMode="always"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
      android:orientation="vertical"
      android:layout_marginStart="@dimen/setting_out_margin"
      android:layout_marginEnd="@dimen/setting_out_margin"
      android:layout_width="match_parent"
      android:layout_height="match_parent">

      <androidx.cardview.widget.CardView
        app:cardCornerRadius="@dimen/setting_bg_radius"
        app:cardBackgroundColor="@color/color_background_container"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
          android:orientation="vertical"
          android:layout_width="match_parent"
          android:layout_height="wrap_content">

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_sub_folder"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:layout_marginTop="@dimen/setting_item_top"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/setting_sub_folder"
              android:textAppearance="@style/setting_item_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              tools:ignore="SpUsage" />

            <TextView
              android:id="@+id/setting_sub_folder_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:ellipsize="marquee"
              android:maxLines="1"
              android:textAppearance="@style/setting_item_info_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintStart_toStartOf="parent"
              android:layout_marginBottom="@dimen/setting_item_bottom"
              tools:ignore="SpUsage"
              tools:text="123456" />
          </androidx.constraintlayout.widget.ConstraintLayout>

          <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="@dimen/setting_item_padding_horizontal"
            android:background="@color/color_on_background_low2" />

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_clear_temp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <com.google.android.material.textview.MaterialTextView
              android:layout_marginTop="@dimen/setting_item_top"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/setting_clear_temp"
              android:textAppearance="@style/setting_item_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              tools:ignore="SpUsage" />

            <com.google.android.material.textview.MaterialTextView
              android:id="@+id/setting_clear_temp_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:ellipsize="marquee"
              android:maxLines="1"
              android:textAppearance="@style/setting_item_info_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintStart_toStartOf="parent"
              android:layout_marginBottom="@dimen/setting_item_bottom"
              tools:ignore="SpUsage"
              />
          </androidx.constraintlayout.widget.ConstraintLayout>

          <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="@dimen/setting_item_padding_horizontal"
            android:background="@color/color_on_background_low2" />

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_sentence_gap"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:layout_marginTop="@dimen/setting_item_top"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/setting_sentence_gap"
              android:textAppearance="@style/setting_item_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              tools:ignore="SpUsage" />

            <TextView
              android:id="@+id/setting_sentence_gap_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:textAppearance="@style/setting_item_info_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintStart_toStartOf="parent"
              android:layout_marginBottom="@dimen/setting_item_bottom"
              tools:ignore="SpUsage"
              tools:text="500" />
          </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
      </androidx.cardview.widget.CardView>

      <androidx.cardview.widget.CardView
        android:visibility="gone"
        app:cardCornerRadius="@dimen/setting_bg_radius"
        app:cardBackgroundColor="@color/color_background_container"
        android:layout_marginTop="@dimen/setting_card_gap"
        app:cardElevation="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
          android:id="@+id/setting_night_mode"
          android:background="?android:attr/selectableItemBackground"
          android:layout_width="match_parent"
          android:layout_height="@dimen/setting_item_big"
          android:orientation="vertical"
          android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/setting_item_text"
            android:text="@string/setting_night_mode"
            app:layout_constrainedWidth="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="SpUsage" />

          <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/setting_night_mode_switch"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
      </androidx.cardview.widget.CardView>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setting_full_gesture_title"
        android:layout_marginStart="8dp"
        android:maxLines="1"
        android:textAppearance="@style/setting_item_info_text"
        android:textSize="14dp"
        android:layout_marginTop="@dimen/setting_card_gap"
        android:fontFamily="sans-serif-medium"
        tools:ignore="SpUsage" />

      <androidx.cardview.widget.CardView
        app:cardCornerRadius="@dimen/setting_bg_radius"
        app:cardBackgroundColor="@color/color_background_container"
        android:layout_marginTop="8dp"
        app:cardElevation="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
          android:orientation="vertical"
          android:layout_width="match_parent"
          android:layout_height="wrap_content">

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_full_gesture"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:id="@+id/full_gesture_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textAppearance="@style/setting_item_text"
              android:text="@string/setting_full_gesture"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              tools:ignore="SpUsage" />

            <ImageView
              android:id="@+id/full_gesture_info"
              app:layout_constraintTop_toTopOf="@id/full_gesture_title"
              app:layout_constraintBottom_toBottomOf="@id/full_gesture_title"
              app:layout_constraintStart_toEndOf="@id/full_gesture_title"
              android:src="@drawable/ic_item_info"
              app:tint="@color/color_on_background"
              android:scaleType="centerInside"
              android:layout_marginStart="-16dp"
              android:layout_marginBottom="18dp"
              android:layout_width="40dp"
              android:layout_height="40dp"
              tools:ignore="ContentDescription" />

            <com.google.android.material.switchmaterial.SwitchMaterial
              android:id="@+id/full_gesture_switch"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toEndOf="parent"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"/>
          </androidx.constraintlayout.widget.ConstraintLayout>

          <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="@dimen/setting_item_padding_horizontal"
            android:background="@color/color_on_background_low2" />

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_left_brightness"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:id="@+id/left_brightness_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textAppearance="@style/setting_item_text"
              android:text="@string/setting_left_brightness"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              tools:ignore="SpUsage" />

            <com.google.android.material.switchmaterial.SwitchMaterial
              android:id="@+id/left_brightness_switch"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toEndOf="parent"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"/>
          </androidx.constraintlayout.widget.ConstraintLayout>

          <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="@dimen/setting_item_padding_horizontal"
            android:background="@color/color_on_background_low2" />

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_right_volume"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:id="@+id/right_volume_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textAppearance="@style/setting_item_text"
              android:text="@string/setting_right_volume"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              tools:ignore="SpUsage" />

            <com.google.android.material.switchmaterial.SwitchMaterial
              android:id="@+id/right_volume_switch"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toEndOf="parent"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"/>
          </androidx.constraintlayout.widget.ConstraintLayout>

          <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="@dimen/setting_item_padding_horizontal"
            android:background="@color/color_on_background_low2" />

          <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setting_long_press_speed"
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setting_item_big"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setting_item_padding_horizontal">

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/setting_long_press_speed"
              android:textAppearance="@style/setting_item_text"
              app:layout_constrainedWidth="true"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              tools:ignore="SpUsage" />

            <TextView
              android:id="@+id/setting_long_press_speed_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textAppearance="@style/setting_item_info_text"
              app:layout_constraintEnd_toEndOf="parent"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_constraintBottom_toBottomOf="parent"
              android:layout_marginEnd="5dp"
              tools:ignore="SpUsage"
              tools:text="0.5X" />
          </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
      </androidx.cardview.widget.CardView>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</LinearLayout>