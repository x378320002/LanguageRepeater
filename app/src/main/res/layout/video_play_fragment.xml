<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/main"
  android:background="@color/main_bg_color"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".MainActivity">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/top_bar"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:layout_width="0dp"
    android:layout_height="44dp">

    <TextView
      android:id="@+id/tv_title"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:textSize="14dp"
      android:textColor="@color/main_text_color"
      android:maxLines="1"
      android:ellipsize="end"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>
  </androidx.constraintlayout.widget.ConstraintLayout>

  <androidx.cardview.widget.CardView
    android:id="@+id/exo_video_view_wrapper"
    app:layout_constraintTop_toBottomOf="@id/top_bar"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintDimensionRatio="16:9"
    android:elevation="0dp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    app:cardCornerRadius="8dp"
    android:layout_width="0dp"
    android:layout_height="0dp">
    <androidx.media3.ui.PlayerView
      android:id="@+id/exo_video_view"
      app:shutter_background_color="@color/main_bg_color_2"
      android:background="@color/main_bg_color_2"
      app:surface_type="texture_view"
      app:show_buffering="always"
      app:auto_show="false"
      app:show_subtitle_button="true"
      app:show_timeout="3000"
      app:show_next_button="true"
      app:use_controller="true"
      app:show_previous_button="true"
      app:show_shuffle_button="false"
      android:layout_width="match_parent"
      android:layout_height="match_parent" />
  </androidx.cardview.widget.CardView>

  <androidx.cardview.widget.CardView
    android:id="@+id/audio_wave_view_wrapper"
    app:layout_constraintTop_toBottomOf="@id/exo_video_view_wrapper"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:elevation="0dp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="8dp"
    android:layout_width="0dp"
    android:layout_height="120dp">

    <com.language.repeater.widgets.AllWaveformView
      android:id="@+id/audio_wave_view"
      android:visibility="gone"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toBottomOf="@id/exo_video_view_wrapper"
      android:layout_width="match_parent"
      android:layout_height="match_parent"/>

    <com.language.repeater.widgets.ScrollWaveformView
      android:id="@+id/audio_progress_wave_view"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toBottomOf="@id/audio_wave_view"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      />
  </androidx.cardview.widget.CardView>

  <com.google.android.flexbox.FlexboxLayout
    android:id="@+id/edit_layout"
    android:visibility="gone"
    tools:visibility="visible"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:background="@drawable/bg_edit_layout"
    app:layout_constraintTop_toBottomOf="@id/audio_wave_view_wrapper"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    app:flexDirection="row"
    app:flexWrap="wrap"
    app:justifyContent="space_evenly"
    android:orientation="horizontal"
    android:layout_width="0dp"
    android:layout_height="wrap_content">

    <LinearLayout
      android:id="@+id/merge_pre"
      android:orientation="vertical"
      android:gravity="center"
      android:layout_width="50dp"
      android:layout_height="60dp">
      <ImageView
        android:src="@drawable/place_hold"
        android:scaleType="centerInside"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="@color/color_tint_edit_selector"
        tools:ignore="ContentDescription" />
      <TextView
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/color_tint_edit_selector"
        android:textSize="10dp"
        android:text="@string/merge_pre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        tools:ignore="SpUsage" />
    </LinearLayout>


    <LinearLayout
      android:id="@+id/merge_next"
      android:orientation="vertical"
      android:gravity="center"
      android:layout_width="50dp"
      android:layout_height="60dp">
      <ImageView
        android:src="@drawable/place_hold"
        android:scaleType="centerInside"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="@color/color_tint_edit_selector"
        tools:ignore="ContentDescription" />
      <TextView
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:textColor="@color/color_tint_edit_selector"
        android:textSize="10dp"
        android:text="@string/merge_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        tools:ignore="SpUsage" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/delete_sentence"
      android:orientation="vertical"
      android:gravity="center"
      android:layout_width="50dp"
      android:layout_height="60dp">
      <ImageView
        android:src="@drawable/place_hold"
        android:scaleType="centerInside"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="@color/color_tint_edit_selector"
        tools:ignore="ContentDescription" />
      <TextView
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/color_tint_edit_selector"
        android:textSize="10dp"
        android:text="@string/delete_sentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        tools:ignore="SpUsage" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/split_sentence"
      android:orientation="vertical"
      android:gravity="center"
      android:layout_width="50dp"
      android:layout_height="60dp">
      <ImageView
        android:src="@drawable/place_hold"
        android:scaleType="centerInside"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="@color/color_tint_edit_selector"
        tools:ignore="ContentDescription" />
      <TextView
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/color_tint_edit_selector"
        android:textSize="10dp"
        android:text="@string/split_sentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        tools:ignore="SpUsage" />
    </LinearLayout>

  </com.google.android.flexbox.FlexboxLayout>

  <androidx.appcompat.widget.LinearLayoutCompat
    android:id="@+id/sub_actions_layout"
    android:orientation="horizontal"
    android:layout_marginTop="5dp"
    app:layout_goneMarginTop="15dp"
    app:layout_constraintTop_toBottomOf="@id/edit_layout"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:gravity="center"
    android:layout_width="0dp"
    android:layout_height="60dp">

    <ImageView
      android:id="@+id/edit_switch"
      android:layout_width="60dp"
      android:layout_height="match_parent"
      android:scaleType="centerInside"
      android:src="@drawable/place_hold"
      app:tint="@color/color_tint_selected_selector"
      tools:ignore="ContentDescription,HardcodedText" />

    <ImageView
      android:id="@+id/play_speed"
      android:layout_width="60dp"
      android:layout_height="match_parent"
      android:scaleType="centerInside"
      android:src="@drawable/place_hold"
      app:tint="@color/color_tint_selected_selector"
      tools:ignore="ContentDescription,HardcodedText" />

    <ImageView
      android:id="@+id/voice_repeat_switch"
      android:layout_width="60dp"
      android:layout_height="match_parent"
      android:scaleType="centerInside"
      android:src="@drawable/ic_ab_selector"
      app:tint="@color/color_tint_selected_selector"
      tools:ignore="ContentDescription,HardcodedText" />

    <ImageView
      android:id="@+id/sub_action_more"
      android:layout_width="60dp"
      android:layout_height="match_parent"
      android:scaleType="centerInside"
      android:src="@drawable/more_vert"
      app:tint="@color/color_tint_selected_selector"
      tools:ignore="ContentDescription,HardcodedText" />
  </androidx.appcompat.widget.LinearLayoutCompat>

  <ImageView
    android:id="@+id/play_pause_btn"
    app:layout_constraintTop_toBottomOf="@+id/sub_actions_layout"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:src="@drawable/ic_play_pause_selector"
    android:background="@drawable/bg_play_pause"
    android:scaleType="center"
    android:layout_width="80dp"
    android:layout_height="80dp"
    app:tint="@color/ic_tint_color"
    tools:ignore="ContentDescription" />

  <ImageView
    android:id="@+id/seek_pre_sentence"
    app:layout_constraintTop_toTopOf="@id/play_pause_btn"
    app:layout_constraintBottom_toBottomOf="@id/play_pause_btn"
    app:layout_constraintEnd_toStartOf="@id/back_sentence_head"
    app:layout_constraintStart_toStartOf="parent"
    android:src="@drawable/ic_pre_sentence"
    android:scaleType="center"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:paddingStart="10dp"
    app:tint="@color/color_tint_selector"
    tools:ignore="ContentDescription,RtlSymmetry" />

  <ImageView
    android:id="@+id/back_sentence_head"
    app:layout_constraintTop_toTopOf="@id/play_pause_btn"
    app:layout_constraintBottom_toBottomOf="@id/play_pause_btn"
    app:layout_constraintEnd_toStartOf="@id/play_pause_btn"
    app:layout_constraintStart_toEndOf="@id/seek_pre_sentence"
    android:src="@drawable/ic_pre_sentence_3"
    android:scaleType="center"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:paddingEnd="10dp"
    app:tint="@color/color_tint_selector"
    tools:ignore="ContentDescription,RtlSymmetry" />

  <ImageView
    android:id="@+id/seek_next_sentence"
    app:layout_constraintTop_toTopOf="@id/play_pause_btn"
    app:layout_constraintBottom_toBottomOf="@id/play_pause_btn"
    app:layout_constraintStart_toEndOf="@id/play_pause_btn"
    app:layout_constraintEnd_toStartOf="@+id/play_list"
    android:src="@drawable/ic_next_sentence"
    android:scaleType="center"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:paddingStart="10dp"
    app:tint="@color/color_tint_selector"
    tools:ignore="ContentDescription,RtlSymmetry" />

  <ImageView
    android:id="@+id/play_list"
    app:layout_constraintTop_toTopOf="@id/play_pause_btn"
    app:layout_constraintBottom_toBottomOf="@id/play_pause_btn"
    app:layout_constraintStart_toEndOf="@id/seek_next_sentence"
    app:layout_constraintEnd_toEndOf="parent"
    android:src="@drawable/ic_list"
    android:scaleType="center"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:paddingEnd="10dp"
    app:tint="@color/color_tint_selector"
    tools:ignore="ContentDescription,RtlSymmetry" />

