<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/main"
  android:background="@color/white"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".MainActivity">

  <Button
    android:id="@+id/select_file_btn"
    android:text="@string/select_file"
    android:layout_marginTop="10dp"
    android:layout_marginStart="15dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"/>

  <Button
    android:id="@+id/select_subtitle"
    android:text="设置字幕"
    app:layout_constraintTop_toTopOf="@id/select_file_btn"
    app:layout_constraintBottom_toBottomOf="@id/select_file_btn"
    app:layout_constraintStart_toEndOf="@id/select_file_btn"
    android:layout_marginStart="5dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:ignore="HardcodedText" />

  <androidx.appcompat.widget.SwitchCompat
    android:id="@+id/voice_repeat_switch"
    android:text="复读"
    android:textOn="开"
    android:textOff="关"
    android:checked="false"
    app:layout_constraintTop_toTopOf="@id/select_file_btn"
    app:layout_constraintBottom_toBottomOf="@id/select_file_btn"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginEnd="15dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:ignore="HardcodedText" />

  <androidx.media3.ui.PlayerView
    android:id="@+id/exo_video_view"
    app:shutter_background_color="@color/PastelGreen"
    android:background="@android:color/black"
    app:surface_type="texture_view"
    app:show_buffering="always"
    app:auto_show="false"
    app:show_subtitle_button="true"
    app:show_timeout="3000"
    app:show_next_button="true"
    app:use_controller="true"
    app:show_previous_button="true"
    app:layout_constraintTop_toBottomOf="@id/select_file_btn"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintDimensionRatio="16:9"
    app:show_shuffle_button="false"
    android:layout_width="0dp"
    android:layout_height="0dp" />

  <com.language.repeater.widgets.AllWaveformView
    android:id="@+id/audio_wave_view"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/exo_video_view"
    android:background="@color/PastelOrange"
    android:layout_width="0dp"
    android:layout_height="30dp"/>

  <com.language.repeater.widgets.ScrollWaveformView
    android:id="@+id/audio_progress_wave_view"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/audio_wave_view"
    android:background="@color/PastelOrange"
    android:layout_width="0dp"
    android:layout_height="100dp"
    />

  <ImageView
    android:id="@+id/play_list"
    app:layout_constraintBottom_toBottomOf="@id/audio_progress_wave_view"
    app:layout_constraintEnd_toEndOf="@id/audio_progress_wave_view"
    android:src="@drawable/media3_icon_playlist_add"
    app:tint="@color/design_default_color_secondary_variant"
    android:padding="8dp"
    android:paddingEnd="18dp"
    android:paddingStart="18dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:ignore="ContentDescription" />


  <com.google.android.flexbox.FlexboxLayout
    app:layout_constraintTop_toBottomOf="@id/audio_progress_wave_view"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="5dp"
    app:alignItems="center"
    app:flexDirection="row"
    app:flexWrap="wrap"
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <Button
      android:id="@+id/voice_previous"
      android:text="上一句"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/voice_next"
      android:text="下一句"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/save_sentence"
      android:text="保存"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/reload_sentence"
      android:text="自动分割"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/goTestPage"
      android:text="GoTest"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/split_sentence"
      android:text="分割句子"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/delete_sentence"
      android:text="删除句子"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/test_action"
      android:text="测试用"
      android:layout_marginStart="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/select_subtitle_dir"
      android:text="设置字幕文件夹"
      android:layout_marginStart="5dp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>

    <Button
      android:id="@+id/history_list"
      android:text="历史记录"
      android:layout_marginStart="5dp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"/>
  </com.google.android.flexbox.FlexboxLayout>



