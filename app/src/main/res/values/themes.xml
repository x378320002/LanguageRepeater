<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Base application theme. -->
<!--  <style name="Base.Theme.LanguageRepeater" parent="Theme.AppCompat.Light.NoActionBar">-->
  <style name="ActivityAnimation" parent="@android:style/Animation.Activity">
    <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
    <item name="android:activityOpenExitAnimation">@anim/slide_out_hold</item>
    <item name="android:activityCloseEnterAnimation">@anim/slide_out_hold</item>
    <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
  </style>

  <style name="Base.Theme.LanguageRepeater" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
    <!-- Customize your light theme here. -->
    <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    <item name="android:windowBackground">@color/main_background</item>
    <item name="android:windowAnimationStyle">@style/ActivityAnimation</item>
  </style>

  <style name="Theme.LanguageRepeater" parent="Base.Theme.LanguageRepeater" />

  <style name="LoadingDialogTheme" parent="Theme.Material3.DayNight.Dialog">
    <item name="android:windowBackground">@android:color/transparent</item>
    <item name="android:windowIsFloating">true</item>
    <item name="android:windowNoTitle">true</item>
    <item name="windowActionBar">false</item>
    <item name="android:windowContentOverlay">@null</item>
  </style>
<!--  Dialog背景是否变暗 -->
<!--  <item name="android:backgroundDimEnabled">false</item>-->
</resources>