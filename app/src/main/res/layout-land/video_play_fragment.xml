<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/main"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".MainActivity">

  <androidx.media3.ui.PlayerView
    android:id="@+id/exo_video_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_bg_color_on"
    app:auto_show="false"
    app:resize_mode="fixed_height"
    app:show_buffering="always"
    app:show_previous_button="false"
    app:show_next_button="false"
    app:show_shuffle_button="false"
    app:show_subtitle_button="false"
    app:show_timeout="0"
    app:controller_layout_id="@layout/my_player_control_view"
    app:shutter_background_color="@color/main_bg_color_on"
    app:surface_type="texture_view"
    app:use_controller="false" />

  <LinearLayout
    android:id="@+id/land_overlay_layout"
    android:visibility="gone"
    tools:visibility="visible"
    android:background="@drawable/bg_edit_layout_land"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:layout_marginEnd="20dp"
    android:layout_width="280dp"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
      android:visibility="gone"
      android:id="@+id/top_bar"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent">

      <ImageView
        android:id="@+id/iv_add"
        android:layout_width="66dp"
        android:layout_height="0dp"
        android:scaleType="center"
        android:src="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/color_tint_selector"
        tools:ignore="ContentDescription,RtlSymmetry" />

      <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/main_text_color"
        android:textSize="14dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_setting"
        app:layout_constraintStart_toEndOf="@id/iv_add"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="SpUsage"
        tools:text="Title" />

      <ImageView
        android:id="@+id/iv_setting"
        android:layout_width="66dp"
        android:layout_height="0dp"
        android:scaleType="center"
        android:src="@drawable/ic_setting"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/color_tint_selector"
        tools:ignore="ContentDescription,RtlSymmetry" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
      android:id="@+id/audio_wave_view_wrapper"
      android:layout_marginTop="5dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintBottom_toTopOf="@id/edit_layout"
      android:elevation="0dp"
      app:cardCornerRadius="8dp"
      android:layout_width="match_parent"
      android:layout_height="100dp">

      <com.language.repeater.widgets.ScrollWaveformView
        android:id="@+id/audio_progress_wave_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

      <!--<ImageView-->
      <!--  android:id="@+id/switch_drag_ab"-->
      <!--  android:layout_width="30dp"-->
      <!--  android:layout_height="30dp"-->
      <!--  android:layout_gravity="bottom|start"-->
      <!--  android:scaleType="centerInside"-->
      <!--  android:src="@drawable/ic_sub_action_edit"-->
      <!--  app:tint="@color/color_tint_selected_selector"-->
      <!--  tools:ignore="ContentDescription,HardcodedText" />-->
    </FrameLayout>

    <!--<View-->
    <!--  android:layout_width="match_parent"-->
    <!--  android:layout_marginTop="10dp"-->
    <!--  android:layout_marginHorizontal="20dp"-->
    <!--  android:background="@color/divider_color_land"-->
    <!--  android:layout_height="1px"/>-->

    <LinearLayout
      android:id="@+id/edit_layout"
      android:layout_width="wrap_content"
      android:layout_height="@dimen/play_video_edit_action_w"
      android:layout_marginStart="15dp"
      android:layout_marginEnd="15dp"
      app:flexDirection="row"
      app:flexWrap="wrap"
      app:justifyContent="space_evenly"
      android:orientation="horizontal"
      app:layout_constraintStart_toStartOf="@id/audio_wave_view_wrapper"
      app:layout_constraintEnd_toEndOf="@id/audio_wave_view_wrapper"
      app:layout_constraintBottom_toBottomOf="parent"
      tools:visibility="visible">

      <LinearLayout
        android:id="@+id/merge_pre"
        android:layout_width="@dimen/play_video_edit_action_w"
        android:layout_height="@dimen/play_video_edit_action_w"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="centerInside"
          android:src="@drawable/ic_edit_merge_left"
          app:tint="@color/ic_tint_color_edit_land"
          tools:ignore="ContentDescription" />
      </LinearLayout>


      <LinearLayout
        android:id="@+id/merge_next"
        android:layout_width="@dimen/play_video_edit_action_w"
        android:layout_height="@dimen/play_video_edit_action_w"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="centerInside"
          android:src="@drawable/ic_edit_merge_right"
          app:tint="@color/ic_tint_color_edit_land"
          tools:ignore="ContentDescription" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/split_sentence"
        android:layout_width="@dimen/play_video_edit_action_w"
        android:layout_height="@dimen/play_video_edit_action_w"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="centerInside"
          android:src="@drawable/ic_edit_split"
          app:tint="@color/ic_tint_color_edit_land"
          tools:ignore="ContentDescription" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/delete_sentence"
        android:layout_width="@dimen/play_video_edit_action_w"
        android:layout_height="@dimen/play_video_edit_action_w"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="centerInside"
          android:src="@drawable/ic_edit_delete"
          app:tint="@color/ic_tint_color_edit_land"
          tools:ignore="ContentDescription" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/insert_sentence"
        android:layout_width="@dimen/play_video_edit_action_w"
        android:layout_height="@dimen/play_video_edit_action_w"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="centerInside"
          android:src="@drawable/ic_edit_insert"
          app:tint="@color/ic_tint_color_edit_land"
          tools:ignore="ContentDescription" />
      </LinearLayout>
    </LinearLayout>

    <View
      android:layout_width="match_parent"
      android:layout_marginHorizontal="20dp"
      android:background="@color/divider_color_land"
      android:layout_height="1px"/>

    <LinearLayout
      android:id="@+id/main_control_layout"
      app:layout_constraintBottom_toTopOf="@id/audio_wave_view_wrapper"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginVertical="5dp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@android:color/transparent"
      android:clipToPadding="false"
      android:gravity="center"
      android:orientation="horizontal"
      android:layoutDirection="ltr">

      <ImageView
        android:id="@+id/seek_pre_sentence"
        android:layout_width="50dp"
        android:layout_height="60dp"
        android:scaleType="center"
        android:src="@drawable/ic_pre_sentence"
        app:tint="@color/color_tint_selector_land"
        tools:ignore="ContentDescription,RtlSymmetry" />

      <ImageView
        android:id="@+id/back_sentence_head"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="center"
        android:src="@drawable/ic_go_sentence_head"
        app:tint="@color/color_tint_selector_land"
        tools:ignore="ContentDescription,RtlSymmetry" />

      <!--android:background="@drawable/bg_play_pause_land"-->
      <ImageView
        android:id="@+id/play_pause_btn"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="center"
        android:src="@drawable/ic_play_pause_selector"
        app:tint="@color/color_tint_selector_land"
        tools:ignore="ContentDescription" />

      <ImageView
        android:id="@+id/seek_next_sentence"
        android:layout_width="50dp"
        android:layout_height="60dp"
        android:scaleType="center"
        android:src="@drawable/ic_next_sentence"
        app:layout_constraintBottom_toBottomOf="@id/play_pause_btn"
        app:layout_constraintEnd_toStartOf="@+id/play_list"
        app:layout_constraintStart_toEndOf="@id/play_pause_btn"
        app:layout_constraintTop_toTopOf="@id/play_pause_btn"
        app:tint="@color/color_tint_selector_land"
        tools:ignore="ContentDescription,RtlSymmetry" />

      <ImageView
        android:id="@+id/play_list"
        android:layout_width="50dp"
        android:layout_height="60dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_list"
        app:tint="@color/color_tint_selector_land"
        tools:ignore="ContentDescription,RtlSymmetry" />
    </LinearLayout>

    <View
      android:layout_width="match_parent"
      android:layout_marginHorizontal="20dp"
      android:background="@color/divider_color_land"
      android:layout_height="1px"/>

    <LinearLayout
      android:id="@+id/sub_actions_layout"
      android:layout_width="wrap_content"
      android:layout_height="@dimen/play_video_sub_action_w"
      android:gravity="center"
      app:layout_constraintStart_toStartOf="@id/main_control_layout"
      app:layout_constraintEnd_toEndOf="@id/main_control_layout"
      app:layout_constraintBottom_toTopOf="@id/main_control_layout">

      <ImageView
        android:id="@+id/switch_drag_ab"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_sub_action_edit"
        app:tint="@color/ic_tint_color_sub_land"
        tools:ignore="ContentDescription,HardcodedText" />

      <FrameLayout
        android:id="@+id/play_speed"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent">

        <ImageView
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:scaleType="centerInside"
          android:src="@drawable/ic_sub_action_speed"
          app:tint="@color/ic_tint_color_sub_land"
          tools:ignore="ContentDescription,HardcodedText" />

        <TextView
          android:id="@+id/play_speed_tv"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="top"
          android:layout_marginTop="30dp"
          android:background="@color/transparent"
          android:gravity="center"
          android:textColor="@color/ic_tint_color_sub_land"
          android:textSize="10dp"
          android:textStyle="bold"
          tools:ignore="SpUsage" />
      </FrameLayout>

      <ImageView
        android:id="@+id/voice_repeat_switch"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_ab_selector"
        app:tint="@color/ic_tint_color_sub_land"
        tools:ignore="ContentDescription,HardcodedText" />

      <FrameLayout
        android:id="@+id/set_timer"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent">

        <ImageView
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:scaleType="centerInside"
          android:src="@drawable/ic_sub_action_time"
          app:tint="@color/ic_tint_color_sub_land"
          tools:ignore="ContentDescription,HardcodedText" />

        <TextView
          android:id="@+id/set_timer_tv"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="top"
          android:layout_marginTop="30dp"
          android:gravity="center"
          android:textColor="@color/ic_tint_color_sub_land"
          android:textSize="10dp"
          android:textStyle="bold"
          android:visibility="gone"
          tools:ignore="SpUsage" />
      </FrameLayout>

      <ImageView
        android:id="@+id/switch_full_screen"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_fullscreen_exit"
        app:tint="@color/ic_tint_color_sub_land"
        tools:ignore="ContentDescription,HardcodedText" />

      <ImageView
        android:id="@+id/sub_action_more"
        android:layout_width="@dimen/play_video_sub_action_w"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_more_vert"
        app:tint="@color/ic_tint_color_sub_land"
        tools:ignore="ContentDescription,HardcodedText" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatSeekBar
      android:id="@+id/video_seek_bar"
      android:progressDrawable="@drawable/bg_custom_seekbar"
      android:minHeight="2dp"
      android:maxHeight="2dp"
      android:max="1000"
      android:layout_marginHorizontal="5dp"
      android:layout_width="match_parent"
      android:layout_height="36dp"/>
  </LinearLayout>

  <ImageView
    android:id="@+id/show_edit_panel"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toStartOf="@id/land_overlay_layout"
    android:background="@drawable/bg_land_show_hide_panel"
    android:src="@drawable/ic_arrow_left"
    app:tint="@color/ic_tint_color_land"
    android:scaleType="centerInside"
    android:layout_width="30dp"
    android:layout_height="40dp"
    tools:ignore="ContentDescription" />
</androidx.constraintlayout.widget.ConstraintLayout>
